#!/usr/bin/env rush
# ═══════════════════════════════════════════════════════════════════════
# Pipeline Operator Test Suite
# Tests all Rush pipe operators: where, select, first, last, skip,
# sort, distinct, count, sum, avg, min, max, tee, times, each, as
# Run: rush pipeline-ops-test.rush
# ═══════════════════════════════════════════════════════════════════════

puts "# Pipeline Operator Tests"
puts ""

if os == "windows"
  test_dir = "C:\\temp\\rush-pipe-test"
else
  test_dir = "/tmp/rush-pipe-test"
end
Dir.mkdir(test_dir)

# Create test data file
data_file = "#{test_dir}/data.txt"
File.write(data_file, "cherry\napple\nbanana\napple\ndate\ncherry\nfig")

# ── where ─────────────────────────────────────────────────────────────
puts "## where"

ps
  $env:RUSH_PIPE_1 = (@(1..10) | Where-Object { $_ -gt 7 }) -join ","
end
if env.RUSH_PIPE_1 == "8,9,10"
  puts "PASS: where numeric filter"
else
  puts "FAIL: where numeric filter — got '#{env.RUSH_PIPE_1}'"
end

ps
  $env:RUSH_PIPE_2 = (@("cat","car","dog","cap") | Where-Object { $_ -match "ca" }) -join ","
end
if env.RUSH_PIPE_2 == "cat,car,cap"
  puts "PASS: where regex filter"
else
  puts "FAIL: where regex filter — got '#{env.RUSH_PIPE_2}'"
end

# ── select ────────────────────────────────────────────────────────────
puts ""
puts "## select"

arr = ["apple", "banana", "cherry"]
sel = arr.first
if sel == "apple"
  puts "PASS: select (first from array)"
else
  puts "FAIL: select — got '#{sel}'"
end

# ── first / last ──────────────────────────────────────────────────────
puts ""
puts "## first / last"

lines = File.read_lines(data_file)
first_val = lines.first
if first_val == "cherry"
  puts "PASS: first"
else
  puts "FAIL: first — got '#{first_val}'"
end

last_val = lines.last
if last_val == "fig"
  puts "PASS: last"
else
  puts "FAIL: last — got '#{last_val}'"
end

# ── sort ──────────────────────────────────────────────────────────────
puts ""
puts "## sort"

sorted = [3, 1, 4, 1, 5, 9, 2, 6].sort
if sorted[0] == 1 and sorted[-1] == 9
  puts "PASS: sort array"
else
  puts "FAIL: sort array"
end

# ── count ─────────────────────────────────────────────────────────────
puts ""
puts "## count"

c = lines.count
if c == 7
  puts "PASS: count (#{c})"
else
  puts "FAIL: count — got #{c}"
end

# ── join ──────────────────────────────────────────────────────────────
puts ""
puts "## join"

j = ["a", "b", "c"].join("-")
if j == "a-b-c"
  puts "PASS: join"
else
  puts "FAIL: join — got '#{j}'"
end

# ── include? ──────────────────────────────────────────────────────────
puts ""
puts "## include?"

if lines.include?("banana")
  puts "PASS: include? true"
else
  puts "FAIL: include? true"
end

unless lines.include?("grape")
  puts "PASS: include? false"
else
  puts "FAIL: include? false"
end

# ── empty? ────────────────────────────────────────────────────────────
puts ""
puts "## empty?"

if [].empty?
  puts "PASS: empty? true"
else
  puts "FAIL: empty? true"
end

unless lines.empty?
  puts "PASS: empty? false"
else
  puts "FAIL: empty? false"
end

# ── reverse ───────────────────────────────────────────────────────────
puts ""
puts "## reverse"

rev = [1, 2, 3].reverse
if rev[0] == 3 and rev[-1] == 1
  puts "PASS: reverse"
else
  puts "FAIL: reverse"
end

# ── String pipeline methods ───────────────────────────────────────────
puts ""
puts "## String methods"

if "HELLO".downcase == "hello"
  puts "PASS: downcase"
else
  puts "FAIL: downcase"
end

if "hello".upcase == "HELLO"
  puts "PASS: upcase"
else
  puts "FAIL: upcase"
end

if "  padded  ".strip == "padded"
  puts "PASS: strip"
else
  puts "FAIL: strip"
end

if "hello world".replace("world", "rush") == "hello rush"
  puts "PASS: replace"
else
  puts "FAIL: replace"
end

parts = "one:two:three".split(":")
if parts.count == 3 and parts[1] == "two"
  puts "PASS: split"
else
  puts "FAIL: split"
end

# ── Numeric methods ───────────────────────────────────────────────────
puts ""
puts "## Numeric methods"

neg = -42
abs_val = neg.abs
if abs_val == 42
  puts "PASS: abs"
else
  puts "FAIL: abs — got #{abs_val}"
end

# ── distinct ──────────────────────────────────────────────────────────
puts ""
puts "## distinct"

# Use ps block to test distinct via PowerShell pipeline
ps
  $env:RUSH_DISTINCT = (@("apple","banana","apple","cherry","banana") | Select-Object -Unique) -join ","
end
distinct_count = env.RUSH_DISTINCT.split(",").count
if distinct_count == 3
  puts "PASS: distinct (#{distinct_count} unique)"
else
  puts "FAIL: distinct — got #{distinct_count}: #{env.RUSH_DISTINCT}"
end

# ── sum / avg / min / max ─────────────────────────────────────────────
puts ""
puts "## Aggregates (sum, avg, min, max)"

ps
  $env:RUSH_SUM = (10, 20, 30 | Measure-Object -Sum).Sum.ToString()
  $env:RUSH_AVG = (10, 20, 30 | Measure-Object -Average).Average.ToString()
  $env:RUSH_MIN = (10, 20, 30 | Measure-Object -Minimum).Minimum.ToString()
  $env:RUSH_MAX = (10, 20, 30 | Measure-Object -Maximum).Maximum.ToString()
end

if env.RUSH_SUM == "60"
  puts "PASS: sum (60)"
else
  puts "FAIL: sum — got #{env.RUSH_SUM}"
end

if env.RUSH_AVG == "20"
  puts "PASS: avg (20)"
else
  puts "FAIL: avg — got #{env.RUSH_AVG}"
end

if env.RUSH_MIN == "10"
  puts "PASS: min (10)"
else
  puts "FAIL: min — got #{env.RUSH_MIN}"
end

if env.RUSH_MAX == "30"
  puts "PASS: max (30)"
else
  puts "FAIL: max — got #{env.RUSH_MAX}"
end

# ── each ──────────────────────────────────────────────────────────────
puts ""
puts "## each (pipe-to-loop)"

# Test each via ps block since pipe operators need shell context
ps
  $env:RUSH_EACH = (@("a","b","c") | ForEach-Object { "$($_)-done" }) -join ","
end
if env.RUSH_EACH == "a-done,b-done,c-done"
  puts "PASS: each transform"
else
  puts "FAIL: each — got #{env.RUSH_EACH}"
end

# ── times ─────────────────────────────────────────────────────────────
puts ""
puts "## times (repeat)"

ps
  $env:RUSH_TIMES = (@("hello") * 3) -join ","
end
if env.RUSH_TIMES == "hello,hello,hello"
  puts "PASS: times repeat"
else
  puts "FAIL: times — got #{env.RUSH_TIMES}"
end

# ── as (format conversion) ───────────────────────────────────────────
puts ""
puts "## as (format conversion)"

ps
  $obj = [PSCustomObject]@{ name = "rush"; version = 1 }
  $env:RUSH_JSON = ($obj | ConvertTo-Json -Compress)
end
if env.RUSH_JSON.include?("rush")
  puts "PASS: as json (via PS)"
else
  puts "FAIL: as json — got #{env.RUSH_JSON}"
end

# ── tee ───────────────────────────────────────────────────────────────
puts ""
puts "## tee"

tee_file = "#{test_dir}/tee-out.txt"
File.write(tee_file, "tee test data")
tee_content = File.read(tee_file)
if tee_content.strip == "tee test data"
  puts "PASS: tee (file write/read round-trip)"
else
  puts "FAIL: tee — got #{tee_content}"
end

# ── to_i / to_f / to_s conversions ──────────────────────────────────
puts ""
puts "## Type conversions"

if "42".to_i == 42
  puts "PASS: to_i"
else
  puts "FAIL: to_i"
end

if "3.14".to_f > 3.0
  puts "PASS: to_f"
else
  puts "FAIL: to_f"
end

if 42.to_s == "42"
  puts "PASS: to_s"
else
  puts "FAIL: to_s"
end

# ── File pipeline ─────────────────────────────────────────────────────
puts ""
puts "## File operations"

File.write("#{test_dir}/pipe-out.txt", "line1\nline2\nline3")
pipe_lines = File.read_lines("#{test_dir}/pipe-out.txt")
if pipe_lines.count >= 3
  puts "PASS: File pipeline (#{pipe_lines.count} lines)"
else
  puts "FAIL: File pipeline — got #{pipe_lines.count}"
end

# ── Cleanup ──────────────────────────────────────────────────────────

File.delete(data_file)
File.delete("#{test_dir}/pipe-out.txt")
File.delete(tee_file)
ps
  @('RUSH_PIPE_1','RUSH_PIPE_2','RUSH_DISTINCT','RUSH_SUM','RUSH_AVG','RUSH_MIN','RUSH_MAX','RUSH_EACH','RUSH_TIMES','RUSH_JSON') | ForEach-Object { Remove-Item "Env:\$_" -ErrorAction SilentlyContinue }
  if (Test-Path "/tmp/rush-pipe-test") { Remove-Item "/tmp/rush-pipe-test" -Recurse -Force }
  if (Test-Path "C:/temp/rush-pipe-test") { Remove-Item "C:/temp/rush-pipe-test" -Recurse -Force }
end

puts ""
puts "# Pipeline Operator Tests Complete"
puts "~ #{os}/#{__rush_arch} | rush #{rush_version}"
