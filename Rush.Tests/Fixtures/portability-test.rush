#!/usr/bin/env rush
# ═══════════════════════════════════════════════════════════════════════
# Rush Cross-Platform Portability Test Suite
# Run: rush portability-test.rush
# Safe on any platform — non-destructive, cleans up after itself.
# ═══════════════════════════════════════════════════════════════════════

puts "# Rush Portability Test Suite"
puts "~ platform: #{os}/#{__rush_arch} | rush #{rush_version}"
puts ""

# ── 1. Variables & Types ─────────────────────────────────────────────
puts "## 1. Variables & Types"

x = 42
if x == 42
  puts "PASS: integer assignment"
else
  puts "FAIL: integer assignment"
end

name = "world"
if name == "world"
  puts "PASS: string assignment"
else
  puts "FAIL: string assignment"
end

flag = true
if flag
  puts "PASS: boolean true"
else
  puts "FAIL: boolean true"
end

nothing = nil
if nothing.nil?
  puts "PASS: nil check"
else
  puts "FAIL: nil check"
end

a, b, c = 1, 2, 3
if a == 1 and b == 2 and c == 3
  puts "PASS: multiple assignment"
else
  puts "FAIL: multiple assignment"
end

n = 10
n += 5
if n == 15
  puts "PASS: compound +="
else
  puts "FAIL: compound +="
end

n -= 3
if n == 12
  puts "PASS: compound -="
else
  puts "FAIL: compound -="
end

n *= 2
if n == 24
  puts "PASS: compound *="
else
  puts "FAIL: compound *="
end

# ── 2. Strings ───────────────────────────────────────────────────────
puts ""
puts "## 2. Strings"

s = "hello world"
if s.upcase == "HELLO WORLD"
  puts "PASS: upcase"
else
  puts "FAIL: upcase"
end

if s.downcase == "hello world"
  puts "PASS: downcase"
else
  puts "FAIL: downcase"
end

if s.length == 11
  puts "PASS: length"
else
  puts "FAIL: length"
end

if s.include?("world")
  puts "PASS: include? true"
else
  puts "FAIL: include? true"
end

unless s.include?("xyz")
  puts "PASS: include? false"
else
  puts "FAIL: include? false"
end

if s.replace("world", "rush") == "hello rush"
  puts "PASS: replace"
else
  puts "FAIL: replace"
end

trimmed = "  spaces  ".strip
if trimmed == "spaces"
  puts "PASS: strip"
else
  puts "FAIL: strip"
end

greeting = "hello #{name}"
if greeting == "hello world"
  puts "PASS: interpolation"
else
  puts "FAIL: interpolation"
end

expr_str = "sum is #{2 + 3}"
if expr_str == "sum is 5"
  puts "PASS: interpolation with expression"
else
  puts "FAIL: interpolation with expression"
end

if s.start_with?("hello")
  puts "PASS: start_with?"
else
  puts "FAIL: start_with?"
end

if s.end_with?("world")
  puts "PASS: end_with?"
else
  puts "FAIL: end_with?"
end

parts = "a,b,c".split(",")
if parts.count == 3
  puts "PASS: split count"
else
  puts "FAIL: split count"
end

if parts[1] == "b"
  puts "PASS: split element"
else
  puts "FAIL: split element"
end

if "hello123" =~ /\d+/
  puts "PASS: regex match"
else
  puts "FAIL: regex match"
end

unless "hello" =~ /\d+/
  puts "PASS: regex no match"
else
  puts "FAIL: regex no match"
end

# ── 3. Arrays ────────────────────────────────────────────────────────
puts ""
puts "## 3. Arrays"

arr = [1, 2, 3, 4, 5]
if arr.count == 5
  puts "PASS: array count"
else
  puts "FAIL: array count"
end

if arr[0] == 1
  puts "PASS: array index 0"
else
  puts "FAIL: array index 0"
end

if arr[-1] == 5
  puts "PASS: array index -1"
else
  puts "FAIL: array index -1"
end

if arr.include?(3)
  puts "PASS: array include?"
else
  puts "FAIL: array include?"
end

unless arr.include?(99)
  puts "PASS: array include? false"
else
  puts "FAIL: array include? false"
end

sorted = [3, 1, 4, 1, 5].sort
if sorted[0] == 1 and sorted[-1] == 5
  puts "PASS: array sort"
else
  puts "FAIL: array sort"
end

joined = ["a", "b", "c"].join(",")
if joined == "a,b,c"
  puts "PASS: array join"
else
  puts "FAIL: array join"
end

empty_arr = []
if empty_arr.empty?
  puts "PASS: empty array"
else
  puts "FAIL: empty array"
end

first_val = arr.first
if first_val == 1
  puts "PASS: array first"
else
  puts "FAIL: array first"
end

last_val = arr.last
if last_val == 5
  puts "PASS: array last"
else
  puts "FAIL: array last"
end

# ── 4. Control Flow ──────────────────────────────────────────────────
puts ""
puts "## 4. Control Flow"

val = "none"
if true
  val = "yes"
else
  val = "no"
end
if val == "yes"
  puts "PASS: if true branch"
else
  puts "FAIL: if true branch"
end

val2 = "none"
if false
  val2 = "yes"
else
  val2 = "no"
end
if val2 == "no"
  puts "PASS: if false branch"
else
  puts "FAIL: if false branch"
end

val3 = "none"
unless false
  val3 = "ran"
end
if val3 == "ran"
  puts "PASS: unless"
else
  puts "FAIL: unless"
end

color = "red"
result = "unknown"
case color
when "red"
  result = "stop"
when "green"
  result = "go"
else
  result = "caution"
end
if result == "stop"
  puts "PASS: case/when"
else
  puts "FAIL: case/when"
end

# Comparison operators
if 5 > 3
  puts "PASS: greater than"
else
  puts "FAIL: greater than"
end

if 3 < 5
  puts "PASS: less than"
else
  puts "FAIL: less than"
end

if 5 >= 5
  puts "PASS: greater or equal"
else
  puts "FAIL: greater or equal"
end

if 3 != 5
  puts "PASS: not equal"
else
  puts "FAIL: not equal"
end

# ── 5. Loops ─────────────────────────────────────────────────────────
puts ""
puts "## 5. Loops"

sum = 0
for i in [1, 2, 3, 4, 5]
  sum = sum + i
end
if sum == 15
  puts "PASS: for..in sum"
else
  puts "FAIL: for..in sum"
end

count = 0
while count < 5
  count = count + 1
end
if count == 5
  puts "PASS: while loop"
else
  puts "FAIL: while loop"
end

letters = []
for x in ["a", "b", "c"]
  letters = letters + [x.upcase]
end
if letters.count == 3
  puts "PASS: for..in with transform"
else
  puts "FAIL: for..in with transform"
end

# Break
found = 0
for i in [1, 2, 3, 4, 5]
  if i == 3
    found = i
    break
  end
end
if found == 3
  puts "PASS: break"
else
  puts "FAIL: break"
end

# ── 6. Functions ─────────────────────────────────────────────────────
puts ""
puts "## 6. Functions"

def add(a, b)
  return a + b
end

r = add(2, 3)
if r == 5
  puts "PASS: function with args"
else
  puts "FAIL: function with args"
end

def greet(who, prefix = "Hello")
  return "#{prefix}, #{who}!"
end

g = greet("Rush")
if g == "Hello, Rush!"
  puts "PASS: function default args"
else
  puts "FAIL: function default args — got '#{g}'"
end

g2 = greet("Rush", "Hi")
if g2 == "Hi, Rush!"
  puts "PASS: function override default"
else
  puts "FAIL: function override default — got '#{g2}'"
end

# ── 7. File/Dir Stdlib ───────────────────────────────────────────────
puts ""
puts "## 7. File/Dir Stdlib"

if os == "windows"
  test_dir = "C:\\temp\\rush-pt"
else
  test_dir = "/tmp/rush-pt"
end

Dir.mkdir(test_dir)
if Dir.exist?(test_dir)
  puts "PASS: Dir.mkdir + exist?"
else
  puts "FAIL: Dir.mkdir + exist?"
end

test_file = "#{test_dir}/test.txt"
File.write(test_file, "hello rush")
if File.exist?(test_file)
  puts "PASS: File.write + exist?"
else
  puts "FAIL: File.write + exist?"
end

content = File.read(test_file)
if content.strip == "hello rush"
  puts "PASS: File.read"
else
  puts "FAIL: File.read — got '#{content.strip}'"
end

File.append(test_file, "\nline two")
lines = File.read_lines(test_file)
if lines.count >= 2
  puts "PASS: File.append + read_lines (#{lines.count} lines)"
else
  puts "FAIL: File.append + read_lines — got #{lines.count}"
end

sz = File.size(test_file)
if sz > 0
  puts "PASS: File.size (#{sz} bytes)"
else
  puts "FAIL: File.size"
end

File.delete(test_file)
unless File.exist?(test_file)
  puts "PASS: File.delete"
else
  puts "FAIL: File.delete"
end

# Dir.list
File.write("#{test_dir}/a.txt", "a")
File.write("#{test_dir}/b.txt", "b")
entries = Dir.list(test_dir)
if entries.count >= 2
  puts "PASS: Dir.list (#{entries.count} entries)"
else
  puts "FAIL: Dir.list — got #{entries.count}"
end

# ── 7b. Paths with Spaces ────────────────────────────────────────────
puts ""
puts "## 7b. Paths with Spaces"

space_dir = "#{test_dir}/rush test space"
Dir.mkdir(space_dir)
File.write("#{space_dir}/hello.txt", "space works")

if Dir.exist?(space_dir)
  puts "PASS: Dir.mkdir with space in name"
else
  puts "FAIL: Dir.mkdir with space in name"
end

space_content = File.read("#{space_dir}/hello.txt")
if space_content.strip == "space works"
  puts "PASS: File.read from spaced path"
else
  puts "FAIL: File.read from spaced path"
end

File.delete("#{space_dir}/hello.txt")

# ── 8. Platform Detection ────────────────────────────────────────────
puts ""
puts "## 8. Platform Detection"

unless os.empty?
  puts "PASS: os is set (#{os})"
else
  puts "FAIL: os is empty"
end

unless __rush_arch.empty?
  puts "PASS: arch is set (#{__rush_arch})"
else
  puts "FAIL: arch is empty"
end

unless rush_version.empty?
  puts "PASS: rush_version is set"
else
  puts "FAIL: rush_version is empty"
end

valid_os = (os == "macos" or os == "linux" or os == "windows")
if valid_os
  puts "PASS: os is valid"
else
  puts "FAIL: os is '#{os}'"
end

platform_ran = false
if os == "macos"
  macos
    platform_ran = true
  end
end
if os == "linux"
  linux
    platform_ran = true
  end
end
if os == "windows"
  win64
    platform_ran = true
  end
end
if platform_ran
  puts "PASS: platform block for #{os}"
else
  puts "FAIL: platform block for #{os}"
end

# Non-matching platform should not run
wrong_platform_ran = false
if os != "macos"
  macos
    wrong_platform_ran = true
  end
end
if os != "linux"
  linux
    wrong_platform_ran = true
  end
end
if os != "windows"
  win64
    wrong_platform_ran = true
  end
end
unless wrong_platform_ran
  puts "PASS: non-matching platform skipped"
else
  puts "FAIL: non-matching platform executed"
end

# ── 9. ps Block ──────────────────────────────────────────────────────
puts ""
puts "## 9. ps Block"

ps
  $env:RUSH_PT_1 = "ps_works"
end
if env.RUSH_PT_1 == "ps_works"
  puts "PASS: ps block env bridge"
else
  puts "FAIL: ps block env bridge — got '#{env.RUSH_PT_1}'"
end

ps
  $env:RUSH_PT_2 = (2 + 3).ToString()
end
if env.RUSH_PT_2 == "5"
  puts "PASS: ps block arithmetic"
else
  puts "FAIL: ps block arithmetic — got '#{env.RUSH_PT_2}'"
end

ps
  $env:RUSH_PT_3 = (1..3 | ForEach-Object { $_ * 2 }) -join ","
end
if env.RUSH_PT_3 == "2,4,6"
  puts "PASS: ps block dollar underscore"
else
  puts "FAIL: ps block dollar underscore — got '#{env.RUSH_PT_3}'"
end

ps
  $env:RUSH_PT_4 = $PSVersionTable.PSVersion.ToString()
end
unless env.RUSH_PT_4.empty?
  puts "PASS: ps block PSVersion (#{env.RUSH_PT_4})"
else
  puts "FAIL: ps block PSVersion empty"
end

# ── 10. Command Substitution ────────────────────────────────────────
puts ""
puts "## 10. Command Substitution"

myhost = $(hostname)
unless myhost.strip.empty?
  puts "PASS: command substitution (#{myhost.strip})"
else
  puts "FAIL: command substitution"
end

# ── 11. Semantic Puts ────────────────────────────────────────────────
puts ""
puts "## 11. Semantic Puts (visual check)"
puts "# heading"
puts "## subheading"
puts "> success message"
puts "! warning message"
puts "!! error message"
puts "~ info message"
puts "PASS: semantic puts (check styling above)"

# ── 12. Environment Variables ────────────────────────────────────────
puts ""
puts "## 12. Environment Variables"

ps
  $env:RUSH_PT_ENV_TEST = "hello_rush"
end
if env.RUSH_PT_ENV_TEST == "hello_rush"
  puts "PASS: env var set + access"
else
  puts "FAIL: env var set + access"
end

# ── 12b. PATH Variable ───────────────────────────────────────────────
puts ""
puts "## 12b. PATH Variable"

# $PATH should be set and non-empty
unless $PATH.empty?
  puts "PASS: $PATH is set"
else
  puts "FAIL: $PATH is empty"
end

# On Windows, $PATH should use forward slashes and colons
# On Unix, $PATH should be same as $env:PATH
if os == "windows"
  if $PATH.include?("/")
    puts "PASS: $PATH uses forward slashes"
  else
    puts "FAIL: $PATH missing forward slashes"
  end

  if $PATH.include?(":")
    puts "PASS: $PATH uses colon separators"
  else
    puts "FAIL: $PATH missing colon separators"
  end

  # Should NOT contain backslashes (those are native, not Rush)
  unless $PATH.include?("\\")
    puts "PASS: $PATH has no backslashes"
  else
    puts "FAIL: $PATH contains backslashes"
  end
else
  # Unix: $PATH should contain colon separators
  if $PATH.include?(":")
    puts "PASS: $PATH uses colon separators (Unix)"
  else
    puts "FAIL: $PATH missing colons"
  end
end

# ── 13. Type Conversions ─────────────────────────────────────────────
puts ""
puts "## 13. Type Conversions"

if "42".to_i == 42
  puts "PASS: to_i"
else
  puts "FAIL: to_i"
end

if "3.14".to_f > 3.0
  puts "PASS: to_f"
else
  puts "FAIL: to_f"
end

if 42.to_s == "42"
  puts "PASS: to_s"
else
  puts "FAIL: to_s"
end

# ── 14. Additional String Methods ────────────────────────────────────
puts ""
puts "## 14. String Methods"

if "hello world".start_with?("hello")
  puts "PASS: start_with?"
else
  puts "FAIL: start_with?"
end

if "hello world".end_with?("world")
  puts "PASS: end_with?"
else
  puts "FAIL: end_with?"
end

if "".empty?
  puts "PASS: empty? true"
else
  puts "FAIL: empty? true"
end

unless "hello".empty?
  puts "PASS: empty? false"
else
  puts "FAIL: empty? false"
end

if "hello".length == 5
  puts "PASS: string length"
else
  puts "FAIL: string length"
end

# ── Cleanup ──────────────────────────────────────────────────────────
ps
  @('RUSH_PT_1','RUSH_PT_2','RUSH_PT_3','RUSH_PT_4','RUSH_PT_ENV_TEST') | ForEach-Object {
    Remove-Item "Env:\$_" -ErrorAction SilentlyContinue
  }
  if (Test-Path "/tmp/rush-pt") { Remove-Item "/tmp/rush-pt" -Recurse -Force }
  if (Test-Path "C:/temp/rush-pt") { Remove-Item "C:/temp/rush-pt" -Recurse -Force }
end

# ── Summary ──────────────────────────────────────────────────────────
puts ""
puts "# Portability Test Complete"
puts "~ #{os}/#{__rush_arch} | rush #{rush_version}"
