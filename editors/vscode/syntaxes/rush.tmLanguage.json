{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Rush",
  "scopeName": "source.rush",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#command-substitution" },
    { "include": "#symbols" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#special-variables" },
    { "include": "#environment-access" },
    { "include": "#stdlib-classes" },
    { "include": "#builtin-functions" },
    { "include": "#keywords" },
    { "include": "#method-calls" },
    { "include": "#operators" },
    { "include": "#function-definition" },
    { "include": "#block-parameters" },
    { "include": "#identifiers" }
  ],
  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.rush",
          "match": "#.*$"
        }
      ]
    },

    "strings": {
      "patterns": [
        { "include": "#string-double-quoted" },
        { "include": "#string-single-quoted" }
      ]
    },

    "string-double-quoted": {
      "name": "string.quoted.double.rush",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.rush" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.rush" }
      },
      "patterns": [
        { "include": "#string-interpolation" },
        { "include": "#string-escape" }
      ]
    },

    "string-interpolation": {
      "name": "meta.embedded.line.rush",
      "begin": "#\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.rush" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.rush" }
      },
      "contentName": "source.rush.embedded",
      "patterns": [
        { "include": "$self" }
      ]
    },

    "string-escape": {
      "name": "constant.character.escape.rush",
      "match": "\\\\(?:[\\\\\"nrt0abfev]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4})"
    },

    "string-single-quoted": {
      "name": "string.quoted.single.rush",
      "begin": "'",
      "end": "'",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.rush" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.rush" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.rush",
          "match": "\\\\[\\\\']"
        }
      ]
    },

    "command-substitution": {
      "name": "meta.command-substitution.rush",
      "begin": "\\$\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.command-substitution.begin.rush" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.command-substitution.end.rush" }
      },
      "contentName": "string.interpolated.command.rush",
      "patterns": [
        { "include": "$self" }
      ]
    },

    "symbols": {
      "patterns": [
        {
          "name": "constant.other.symbol.rush",
          "match": "(?<![:\\w]):[a-zA-Z_]\\w*(?:[?!])?\\b"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.rush",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.rush",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.octal.rush",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.binary.rush",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.integer.rush",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.rush",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.rush",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.nil.rush",
          "match": "\\bnil\\b"
        }
      ]
    },

    "special-variables": {
      "patterns": [
        {
          "name": "variable.language.exit-status.rush",
          "match": "\\$\\?"
        },
        {
          "name": "variable.other.rush",
          "match": "\\$[a-zA-Z_]\\w*"
        }
      ]
    },

    "environment-access": {
      "patterns": [
        {
          "match": "\\b(env)(\\.)(\\w+)",
          "captures": {
            "1": { "name": "variable.language.environment.rush" },
            "2": { "name": "punctuation.accessor.dot.rush" },
            "3": { "name": "variable.other.environment.rush" }
          }
        },
        {
          "match": "\\b(env)(\\[)",
          "captures": {
            "1": { "name": "variable.language.environment.rush" },
            "2": { "name": "punctuation.section.bracket.begin.rush" }
          }
        }
      ]
    },

    "stdlib-classes": {
      "patterns": [
        {
          "name": "support.class.rush",
          "match": "\\b(?:File|Dir|Time)\\b"
        }
      ]
    },

    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.rush",
          "match": "\\b(?:puts|print|warn|die|ask|sleep|exit|ping)\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.rush",
          "match": "\\b(?:if|elsif|else|unless|match|case|when)\\b"
        },
        {
          "name": "keyword.control.loop.rush",
          "match": "\\b(?:for|in|while|until|loop|do|next|continue|break)\\b"
        },
        {
          "name": "keyword.control.flow.rush",
          "match": "\\b(?:return|begin|raise)\\b"
        },
        {
          "name": "keyword.control.exception.rush",
          "match": "\\b(?:try|rescue|ensure)\\b"
        },
        {
          "name": "keyword.control.end.rush",
          "match": "\\bend\\b"
        },
        {
          "name": "keyword.other.function-definition.rush",
          "match": "\\bdef\\b"
        },
        {
          "name": "keyword.other.class.rush",
          "match": "\\b(?:class|attr|self|super|enum)\\b"
        },
        {
          "name": "keyword.control.platform.rush",
          "match": "\\b(?:macos|linux|win64|win32|ps|ps5|isssh)\\b"
        },
        {
          "name": "keyword.operator.logical.rush",
          "match": "\\b(?:and|or|not)\\b"
        }
      ]
    },

    "function-definition": {
      "patterns": [
        {
          "match": "\\b(def)\\s+([a-zA-Z_]\\w*[?!]?)",
          "captures": {
            "1": { "name": "keyword.other.function-definition.rush" },
            "2": { "name": "entity.name.function.rush" }
          }
        }
      ]
    },

    "method-calls": {
      "patterns": [
        {
          "comment": "Safe navigation operator method call: &.method",
          "match": "(&\\.)(each|select|reject|map|flat_map|sort_by|first|last|count|any\\?|all\\?|group_by|uniq|reverse|join|to_json|to_csv|include\\?|sort|skip|skip_while|push|compact|flatten|strip|lstrip|rstrip|upcase|downcase|split|split_whitespace|lines|trim_end|start_with\\?|end_with\\?|empty\\?|nil\\?|ljust|rjust|replace|sub|gsub|scan|match|round|abs|times|to_currency|to_filesize|to_percent|to_i|to_f|to_s|red|green|blue|cyan|yellow|magenta|white|gray)",
          "captures": {
            "1": { "name": "keyword.operator.safe-navigation.rush" },
            "2": { "name": "support.function.method.rush" }
          }
        },
        {
          "comment": "Known Rush methods after dot operator",
          "match": "(?<=\\.)(each|select|reject|map|flat_map|sort_by|first|last|count|any\\?|all\\?|group_by|uniq|reverse|join|to_json|to_csv|include\\?|sort|skip|skip_while|push|compact|flatten|strip|lstrip|rstrip|upcase|downcase|split|split_whitespace|lines|trim_end|start_with\\?|end_with\\?|empty\\?|nil\\?|ljust|rjust|replace|sub|gsub|scan|match|round|abs|times|to_currency|to_filesize|to_percent|to_i|to_f|to_s|red|green|blue|cyan|yellow|magenta|white|gray)\\b",
          "name": "support.function.method.rush"
        },
        {
          "comment": "Generic method call after dot",
          "match": "(?<=\\.)[a-zA-Z_]\\w*[?!]?(?=\\s*[({]|\\b)",
          "name": "entity.name.function.method.rush"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.rush",
          "match": "(?:==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.match.rush",
          "match": "(?:=~|!~)"
        },
        {
          "name": "keyword.operator.assignment.compound.rush",
          "match": "(?:\\+=|-=)"
        },
        {
          "name": "keyword.operator.assignment.rush",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.logical.rush",
          "match": "(?:&&|\\|\\|)"
        },
        {
          "name": "keyword.operator.range.rush",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.safe-navigation.rush",
          "match": "&\\."
        },
        {
          "name": "keyword.operator.arithmetic.rush",
          "match": "(?:\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.pipe.rush",
          "match": "(?<!\\|)\\|(?!\\|)"
        }
      ]
    },

    "block-parameters": {
      "patterns": [
        {
          "comment": "Block parameter: { |x, y| ... }",
          "begin": "\\{\\s*\\|",
          "end": "\\|",
          "beginCaptures": {
            "0": { "name": "punctuation.section.block.begin.rush" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.separator.block-parameter.rush" }
          },
          "patterns": [
            {
              "name": "variable.parameter.block.rush",
              "match": "[a-zA-Z_]\\w*"
            },
            {
              "name": "punctuation.separator.comma.rush",
              "match": ","
            }
          ]
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.rush",
          "match": "\\b[a-z_]\\w*\\b"
        },
        {
          "name": "entity.name.type.rush",
          "match": "\\b[A-Z]\\w*\\b"
        }
      ]
    }
  }
}
